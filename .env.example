# Primary database, recommended: Neon
DATABASE_URL=postgresql://postgres:password@host:5432/database

# Optional Supabase mirror for runtime on Cloudflare Workers
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Optional direct Postgres URL for local maintenance scripts only
MIRROR_DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# Set true if you want API writes to fail when mirror sync fails
DB_MIRROR_STRICT=false

# App settings
JWT_SECRET=replace_with_a_long_random_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base64-encoded 32-byte key for encrypting accounts.temp_password
# Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ACCOUNT_SECRET_KEY=replace_with_base64_32_byte_key
