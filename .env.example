# Primary database (Neon / Postgres)
DATABASE_URL=postgresql://postgres:password@host:5432/database

# Supabase mirror config
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_publishable_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Set true if API writes must fail whenever mirror sync fails
DB_MIRROR_STRICT=false

# Firebase sale add config
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_private_key\n-----END PRIVATE KEY-----\n"
FIREBASE_INCOMES_COLLECTION=incomes
FIREBASE_INCOME_USER_ID=EMPTY
SUPABASE_TRADING_TABLE=incomes
SUPABASE_TRADING_USER_ID=EMPTY

# App settings
JWT_SECRET=replace_with_a_long_random_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base64-encoded 32-byte key for encrypting accounts.temp_password
# Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ACCOUNT_SECRET_KEY=replace_with_base64_32_byte_key
